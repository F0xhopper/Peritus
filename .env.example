# =============================================================================
# Peritus – Environment Variables
# Copy this file to .env and fill in your keys.
# =============================================================================

# ── LLM ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ── Embeddings ────────────────────────────────────────────────────────────────
VOYAGE_API_KEY=pa-...
VOYAGE_MODEL=voyage-3

# ── Vector Store ──────────────────────────────────────────────────────────────
PINECONE_API_KEY=...
PINECONE_INDEX_NAME=peritus
PINECONE_ENVIRONMENT=us-east-1

# ── Source Discovery ──────────────────────────────────────────────────────────
EXA_API_KEY=...
FIRECRAWL_API_KEY=...   # Optional – richer content extraction

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_BASE_PATH=./storage/peritus

# ── Tuning ────────────────────────────────────────────────────────────────────
MAX_PATHS_PER_CHUNK=15
MAX_SOURCE_DOCS=20
